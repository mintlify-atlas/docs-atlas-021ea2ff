  "keyFeatures": [
    "Public court availability booking system with real-time slot checking",
    "Multi-location inventory management (Main, Jacinto Ríos, Rincón)",
    "JWT-based authentication with role-based access control and scopes",
    "Admin dashboard with sales, reservations, and activity statistics",
    "Tournament management with public visibility and admin control",
    "Employee management with per-location access restrictions",
    "Automatic reservation expiration service",
    "Neon PostgreSQL (serverless) integration with connection pooling",
    "Vercel deployment with Express backend and Vite frontend",
    "Rate limiting, CORS, Helmet security middleware"
  ],
